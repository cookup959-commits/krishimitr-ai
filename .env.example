
DB_HOST=postgresql://postgres.your-project-ref:your-password@aws-0-us-east-1.pooler.supabase.com:6543/postgres?sslmode=require


# Cache Configuration
# Set to redis://localhost:6379 for redis caching
# Fallback to local memory cache if redis is not available
REDIS_URL=redis://localhost:6379

# Security Config
JWT_SECRET=supersecretjwtkeychangeit12345!
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120

# AI Services API Keys
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Services Host URLs (for API Gateway and AI Agent internal calls)
CROP_SERVICE_URL=http://localhost:8001
DISEASE_SERVICE_URL=http://localhost:8002
WEATHER_SERVICE_URL=http://localhost:8003
MARKET_SERVICE_URL=http://localhost:8004
AGENT_SERVICE_URL=http://localhost:8005
GATEWAY_SERVICE_URL=http://localhost:8000
